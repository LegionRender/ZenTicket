# Clave de API de Gemini (Requerido para el OCR real de los tickets)
GEMINI_API_KEY=

# Credenciales de Email Real (SMTP)
# Configura éstas en Settings > Secrets de AI Studio para recibir correos reales
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=contacto@zenticket.mx
SMTP_PASS=

# Referencia de acceso del buzón
# IMAP SSL: 993
# POP3 SSL: 995
# SMTP TLS: 587
# SMTPS: 465

# Destino para notificaciones internas de nuevos leads
LEADS_NOTIFICATION_TO=
