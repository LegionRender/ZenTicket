# URL pública de la aplicación
APP_PUBLIC_URL=http://localhost:5173

# Credenciales de Mercado Pago (Producción o Sandbox)
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Credenciales de PayPal (Producción o Sandbox)
PAYPAL_CLIENT_ID=ATxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=ELxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_MODE=sandbox

# Credenciales de Stripe (Producción o Sandbox)
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# URLs opcionales de redirección personalizada de cobros (por defecto se construyen con APP_PUBLIC_URL)
BILLING_SUCCESS_URL=http://localhost:5173/workspace?tab=cuenta&status=success
BILLING_FAILURE_URL=http://localhost:5173/workspace?tab=cuenta&status=failure
BILLING_PENDING_URL=http://localhost:5173/workspace?tab=cuenta&status=pending
