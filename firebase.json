{
  "firestore": [
    {
      "database": "(default)",
      "rules": "firestore.rules"
    },
    {
      "database": "ai-studio-1f1e2a82-b500-4db2-9cf3-751b301c35ee",
      "rules": "firestore.rules"
    }
  ],
  "functions": [
    {
      "source": "firebase/functions",
      "runtime": "nodejs20",
      "codebase": "default"
    },
    {
      "source": "runner",
      "runtime": "nodejs20",
      "codebase": "runner"
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
