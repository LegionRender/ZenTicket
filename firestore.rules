rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "legionrender@gmail.com" ||
        request.auth.token.email == "ricardo@zenticket.mx" ||
        request.auth.token.admin == true ||
        request.auth.token.role == "admin"
      );
    }

    function ticketClientCreateIsSafe() {
      return !request.resource.data.keys().hasAny([
        'invoiceId', 'jobId', 'activeInvoiceJobId', 'connectorId', 'portalMapId',
        'isCfdiValidated', 'cfdiValidated', 'satValidated', 'satStatus',
        'validationStatus', 'xmlStoragePath', 'pdfStoragePath', 'folioFiscal',
        'runnerError', 'runnerDiagnostics', 'attemptId', 'leaseUntil', 'lockedBy'
      ]);
    }

    function ticketClientUpdateIsSafe() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return !changed.hasAny([
        'invoiceId', 'jobId', 'activeInvoiceJobId', 'connectorId', 'portalMapId',
        'isCfdiValidated', 'cfdiValidated', 'satValidated', 'satStatus',
        'validationStatus', 'xmlStoragePath', 'pdfStoragePath', 'folioFiscal',
        'runnerError', 'runnerDiagnostics', 'attemptId', 'leaseUntil', 'lockedBy'
      ]) && !(changed.hasAny(['status']) && request.resource.data.status in [
        'cfdi_validated', 'invoice_obtained', 'sat_validated', 'succeeded'
      ]);
    }

    // Fiscal Profiles rules
    // Path: fiscalProfiles/{userId}
    match /fiscalProfiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Users rules
    // Path: users/{userId}
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Subscriptions rules
    // Path: subscriptions/{userId}
    match /subscriptions/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // Tickets rules
    // Path: tickets/{ticketId}
    match /tickets/{ticketId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && ticketClientCreateIsSafe();
      allow update: if (isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == resource.data.userId && ticketClientUpdateIsSafe()) || isAdmin();
      allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Connectors rules
    // Path: connectors/{connectorId}
    match /connectors/{connectorId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /connectors/{connectorId}/versions/{versionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /portal_learning_memory/{patternId} {
      allow read, write: if isAdmin();
    }

    // Invoices rules nested under users
    match /users/{userId}/invoices/{invoiceId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // Collection Group rules to allow admin audit queries
    match /{path=**}/invoices/{invoiceId} {
      allow read: if isAdmin();
    }

    // Automation Trainings rules
    // Path: automation_trainings/{trainingId}
    match /automation_trainings/{trainingId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /connector_discovery_jobs/{jobId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /connector_discovery_outbox/{outboxId} {
      allow read, write: if false;
    }

    match /connector_patch_proposals/{proposalId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Training Requests rules for common users
    // Path: training_requests/{requestId}
    match /training_requests/{requestId} {
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly(['userId', 'storeName', 'rfc', 'officialBillingUrl', 'createdAt']);
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // OCR operations written by Cloud Functions.
    match /ocr_jobs/{jobId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /ocr_retry_queue/{queueId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /ocr_alerts/{alertId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAdmin();
    }
    // Invoice Jobs rules
    match /invoice_jobs/{jobId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /diagnostic_summaries/{summaryId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /runner_diagnostics/{diagnosticId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    // Portal Maps rules
    match /portal_maps/{mapId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Runner Logs rules
    match /runner_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // Payment Methods rules
    match /paymentMethods/{paymentMethodId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow write: if isAdmin();
    }

    // Notifications rules
    match /notifications/{notificationId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
