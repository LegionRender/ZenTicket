rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "legionrender@gmail.com" ||
        request.auth.token.email == "ricardo@zenticket.mx" ||
        request.auth.token.email.matches(".*legionrender.*") ||
        request.auth.token.email.matches(".*ricardo.*")
      );
    }

    // Fiscal Profiles rules
    // Path: fiscalProfiles/{userId}
    match /fiscalProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Users rules
    // Path: users/{userId}
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Tickets rules
    // Path: tickets/{ticketId}
    match /tickets/{ticketId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (isSignedIn() && (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid)) || isAdmin();
      allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Connectors rules
    // Path: connectors/{connectorId}
    match /connectors/{connectorId} {
      allow read: if isSignedIn();
      allow create: if (isSignedIn() && request.resource.data.userId == request.auth.uid) || isAdmin();
      allow update: if (isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Invoices rules nested under users
    match /users/{userId}/invoices/{invoiceId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Collection Group rules to allow admin audit queries
    match /{path=**}/invoices/{invoiceId} {
      allow read: if isAdmin();
    }

    // Automation Trainings rules
    // Path: automation_trainings/{trainingId}
    match /automation_trainings/{trainingId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Training Requests rules for common users
    // Path: training_requests/{requestId}
    match /training_requests/{requestId} {
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly(['userId', 'storeName', 'rfc', 'officialBillingUrl', 'createdAt']);
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // OCR operations written by Cloud Functions.
    match /ocr_jobs/{jobId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /ocr_retry_queue/{queueId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /ocr_alerts/{alertId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAdmin();
    }
    // Invoice Jobs rules
    match /invoice_jobs/{jobId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Portal Maps rules
    match /portal_maps/{mapId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Runner Logs rules
    match /runner_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
